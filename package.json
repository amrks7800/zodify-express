{
  "name": "zodify-express",
  "version": "0.1.3",
  "description": "Type-safe Express route definitions with Zod validation. Infer req.body, req.query, req.params, and custom properties like req.user automatically.",
  "license": "MIT",
  "type": "module",
  "source": "./src/index.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bunchee",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "keywords": [
    "express",
    "zod",
    "validation",
    "typescript",
    "type-safe",
    "middleware",
    "route",
    "defineRoute"
  ],
  "peerDependencies": {
    "express": ">=4",
    "zod": ">=4"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "bunchee": "^6.11.0",
    "express": "^5.2.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "zod": "^4.4.3"
  }
}
